//@version=6
indicator("IBD Daily Chart", overlay=true)

// --- Cài đặt đầu vào ---
len20  = input.int(20, "SMA 20", minval=1)
len50  = input.int(50, "SMA 50", minval=1)
len200 = input.int(200, "SMA 200", minval=1)

// --- Toggle bật/tắt từng component ---
showMA20    = input.bool(true, "MA 20", group="Hiển thị")
showMA50    = input.bool(true, "MA 50", group="Hiển thị")
showMA150   = input.bool(true, "MA 150", group="Hiển thị")
showMA200   = input.bool(true, "MA 200", group="Hiển thị")
showPivots  = input.bool(true, "Đỉnh/Đáy", group="Hiển thị")
showGaps    = input.bool(true, "Gap marker", group="Hiển thị")
show52wHigh = input.bool(true, "52W High", group="Hiển thị")
showBreakout = input.bool(true, "Breakout (B)", group="Hiển thị")

// --- Thanh HLC kiểu IBD (không có open tick) ---
isUp = close >= close[1]
barCol = isUp ? color.black : color.red

plotcandle(close, high, low, close, color=color.new(barCol, 100), wickcolor=barCol, bordercolor=barCol)
plotbar(close, high, low, close, color=barCol)

// --- Đường trung bình động ---
ma20  = ta.sma(close, len20)
ma50  = ta.sma(close, len50)
ma200 = ta.sma(close, len200)
ma150 = ta.sma(close, 150)  // MA30 tuần, dùng cho Stage Analysis

plot(showMA20 ? ma20 : na,  "MA 20",  color=color.orange, linewidth=2)
plot(showMA50 ? ma50 : na,  "MA 50",  color=color.red,    linewidth=2)
plot(showMA200 ? ma200 : na, "MA 200", color=#00BFFF,      linewidth=2)

// --- Đường MA 150 (≈ MA30 tuần, dùng cho Stage Analysis) ---
plot(showMA150 ? ma150 : na, "MA 150", color=color.purple, linewidth=2)

// --- Phát hiện đỉnh / đáy (Pivot) ---
pivotLen = input.int(30, "Pivot Lookback", minval=2, group="Pivots")

ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

// Vẽ label đỉnh (phía trên thanh bar, lùi lại pivotLen bars)
if not na(ph) and showPivots
    label.new(bar_index - pivotLen, ph, str.tostring(ph, format.mintick),
         style=label.style_label_down, color=color.white,
         textcolor=color.black, size=size.small,
         text_formatting=text.format_bold)

// Vẽ label đáy (phía dưới thanh bar, lùi lại pivotLen bars)
if not na(pl) and showPivots
    label.new(bar_index - pivotLen, pl, str.tostring(pl, format.mintick),
         style=label.style_label_up, color=color.white,
         textcolor=color.black, size=size.small,
         text_formatting=text.format_bold)

// --- Đánh dấu Gap mạnh (khoảng trống giá đáng tin cậy) ---
// Chỉ hiện gap khi biên độ gap > X% giá (mặc định 2%)
gapPct = input.float(2.0, "Gap tối thiểu (%)", minval=0.5, step=0.5, group="Gaps")
gapUp   = open > high[1] and (open - high[1]) / close[1] * 100 > gapPct
gapDown = open < low[1] and (low[1] - open) / close[1] * 100 > gapPct

plotshape(gapUp and showGaps, title="Gap Up", style=shape.xcross,
     location=location.belowbar, color=color.green, size=size.tiny, text="G")
plotshape(gapDown and showGaps, title="Gap Down", style=shape.xcross,
     location=location.abovebar, color=color.red, size=size.tiny, text="G")

// --- Đường 52-week High (đỉnh 252 ngày) ---
weekHigh252 = ta.highest(close, 252)
plot(show52wHigh ? weekHigh252 : na, "52W High", color=color.purple, linewidth=1, linestyle=plot.linestyle_dashed)

// --- Bảng thông tin (góc trên phải) ---
// Đỏ = giá dưới MA (âm), Xanh = giá trên MA (dương)
showTable = input.bool(true, "Show MA Distance Table", group="Table")

// Tính ATR 14 ngày (biên độ trung bình)
atrValue = ta.atr(14)

// Đếm số ngày liên tiếp tăng/giảm
var int streak = 0
if close > close[1]
    streak := streak[1] >= 0 ? streak[1] + 1 : 1
else if close < close[1]
    streak := streak[1] <= 0 ? streak[1] - 1 : -1
else
    streak := 0

// Tính Up/Down Volume Ratio 50 ngày (tỷ lệ vol ngày tăng / vol ngày giảm)
// > 1.5 = tích lũy tốt, < 0.7 = phân phối
upVol50   = math.sum(close >= close[1] ? volume : 0, 50)
dnVol50   = math.sum(close < close[1] ? volume : 0, 50)
udRatio   = dnVol50 > 0 ? upVol50 / dnVol50 : 0.0

// Đếm số phiên phân phối trong 25 ngày gần nhất (O'Neil)
// Phiên phân phối = giá giảm > 0.2% + volume tăng so với phiên trước
// Xóa phiên khi: quá 25 ngày HOẶC giá đã rally ≥ 5% kể từ close phiên đó
// (Dùng cách đơn giản: đếm phiên dist mà close phiên đó + 5% > giá hiện tại)
isDistDay = close < close[1] * 0.998 and volume > volume[1]

// Đếm phiên phân phối chưa bị "defeated" (giá chưa rally 5% từ close phiên dist)
var int distDayCount = 0
distDayCount := 0
for i = 1 to 25
    if close[i] < close[i + 1] * 0.998 and volume[i] > volume[i + 1]
        // Đây là phiên phân phối — chỉ đếm nếu giá hiện tại CHƯA rally 5% từ close phiên đó
        if close < close[i] * 1.05
            distDayCount += 1
        // Nếu close hiện tại >= close[i] * 1.05 → phiên đó bị "defeated", không đếm

// --- Main Force Score (phát hiện smart money) ---
// Kết hợp 3 yếu tố: Demand, Supply, Price → điểm 0-100
volAvg20 = ta.sma(volume, 20)
volAvg50MF = ta.sma(volume, 50)

// Close Position: (close - low) / (high - low)
closePos = high != low ? (close - low) / (high - low) : 0.5
closePos5 = ta.sma(closePos, 5)

// Demand: volume ngày tăng 10 ngày / vol avg 20 ngày
upVolSum10 = math.sum(close > close[1] ? volume : 0, 10)
upDays10   = math.sum(close > close[1] ? 1 : 0, 10)
demandRatio = volAvg20 > 0 ? upVolSum10 / (volAvg20 * 10) : 0

// Supply: volume ngày giảm 10 ngày (càng thấp càng tốt)
dnVolSum10 = math.sum(close < close[1] ? volume : 0, 10)
supplyRatio = volAvg20 > 0 ? dnVolSum10 / (volAvg20 * 10) : 0

// Support hold: giá giữ trên MA20 và MA50 tốt không
supportScore = (close > ma20 ? 0.5 : 0) + (close > ma50 ? 0.5 : 0)

// Tính Main Force Score (0-100)
demandScore = math.max(0, math.min(demandRatio / 0.6, 1.0))  // Normalize: 0.6 = baseline
supplyScore = math.max(0, math.min((1.0 - supplyRatio) / 0.6, 1.0))  // Vol bán thấp = tốt
priceScore  = closePos5 * 0.4 + supportScore * 0.4 + (close > ta.highest(high, 20)[1] ? 0.2 : 0)

mainForceScore = math.round((demandScore * 38 + supplyScore * 34 + priceScore * 28))

// Tính Minervini Trend Template (SEPA) — 8 điều kiện Stage 2
// 1. Giá > MA150 | 2. Giá > MA200 | 3. MA150 > MA200
// 4. MA200 đang tăng (so với 20 ngày trước) | 5. Giá > MA50
// 6. Giá cách 52-week low ≥ 25% | 7. Giá cách 52-week high ≤ 25%
// 8. (Bỏ RS rating vì cần data benchmark)
weekLow252  = ta.lowest(close, 252)

cond1 = close > ma150
cond2 = close > ma200
cond3 = ma150 > ma200
cond4 = ma200 > ma200[20]  // MA200 đang tăng
cond5 = close > ma50
cond6 = ((close - weekLow252) / weekLow252 * 100) >= 25  // Cách 52w low ≥ 25%
cond7 = ((weekHigh252 - close) / weekHigh252 * 100) <= 25  // Cách 52w high ≤ 25%

// Đếm số điều kiện đạt (tối đa 7)
trendScore = (cond1 ? 1 : 0) + (cond2 ? 1 : 0) + (cond3 ? 1 : 0) + (cond4 ? 1 : 0) + (cond5 ? 1 : 0) + (cond6 ? 1 : 0) + (cond7 ? 1 : 0)

// --- Base Count (O'Neil) ---
// Đếm số lần breakout pivot high trong uptrend hiện tại
// Reset khi stock rơi xuống dưới MA200 (kết thúc uptrend)
var int baseCount = 0
var float lastPivotHigh = 0.0
var bool waitForNewPivot = false  // Chờ pivot mới sau mỗi breakout

// Khi có pivot high mới → cập nhật mức pivot, cho phép trigger breakout
if not na(ph)
    lastPivotHigh := ph
    waitForNewPivot := false

// Khi giá breakout qua pivot high gần nhất → tăng base count
breakoutSignal = close > lastPivotHigh and close[1] <= lastPivotHigh and lastPivotHigh > 0 and not waitForNewPivot
if breakoutSignal
    baseCount += 1
    waitForNewPivot := true  // Chặn trigger lại cho đến khi có pivot mới

// Hiện chữ "B" trên chart khi breakout pivot
plotshape(breakoutSignal and showBreakout, title="Breakout", style=shape.triangleup,
     location=location.belowbar, color=color.blue, size=size.tiny, text="B")

// Reset base count khi stock rơi khỏi uptrend (giá < MA200 liên tiếp 3 phiên)
// Không reset nếu chỉ xuyên thủng giả 1-2 phiên rồi bật lên ngay
belowMA200count = ta.barssince(close >= ma200)
if belowMA200count >= 3
    baseCount := 0
    lastPivotHigh := 0.0
    waitForNewPivot := false

var table maTable = table.new(position.top_right, 2, 12,
     bgcolor=color.new(color.white, 0),
     frame_color=color.black, frame_width=1,
     border_color=color.gray, border_width=1)

// Hàm chọn màu: âm = đỏ, dương = xanh
distColor(pct) =>
    pct < 0 ? color.red : color.green

if barstate.islast and showTable
    dist20  = (close - ma20) / ma20 * 100
    dist50  = (close - ma50) / ma50 * 100
    dist200 = (close - ma200) / ma200 * 100

    // Tiêu đề bảng
    table.cell(maTable, 0, 0, "Chỉ số", text_color=color.white,
         bgcolor=color.black, text_formatting=text.format_bold)
    table.cell(maTable, 1, 0, "Giá trị", text_color=color.white,
         bgcolor=color.black, text_formatting=text.format_bold)

    // Khoảng cách từ MA 20
    table.cell(maTable, 0, 1, "MA 20", text_color=color.black)
    table.cell(maTable, 1, 1, str.tostring(dist20, "#.##") + "%",
         text_color=distColor(dist20), text_formatting=text.format_bold)

    // Khoảng cách từ MA 50
    table.cell(maTable, 0, 2, "MA 50", text_color=color.black)
    table.cell(maTable, 1, 2, str.tostring(dist50, "#.##") + "%",
         text_color=distColor(dist50), text_formatting=text.format_bold)

    // Khoảng cách từ MA 200
    table.cell(maTable, 0, 3, "MA 200", text_color=color.black)
    table.cell(maTable, 1, 3, str.tostring(dist200, "#.##") + "%",
         text_color=distColor(dist200), text_formatting=text.format_bold)

    // ATR 14 ngày (% so với giá)
    atrPct = atrValue / close * 100
    table.cell(maTable, 0, 4, "ATR(14)", text_color=color.black)
    table.cell(maTable, 1, 4, str.tostring(atrPct, "#.##") + "%",
         text_color=color.black, text_formatting=text.format_bold)

    // Số ngày liên tiếp tăng/giảm
    streakText = streak > 0 ? "▲" + str.tostring(streak) : streak < 0 ? "▼" + str.tostring(math.abs(streak)) : "—"
    streakCol  = streak > 0 ? color.green : streak < 0 ? color.red : color.black
    table.cell(maTable, 0, 5, "Streak", text_color=color.black)
    table.cell(maTable, 1, 5, streakText,
         text_color=streakCol, text_formatting=text.format_bold)

    // % khoảng cách từ đỉnh 52 tuần
    dist52w = (close - weekHigh252) / weekHigh252 * 100
    table.cell(maTable, 0, 6, "52W High", text_color=color.black)
    table.cell(maTable, 1, 6, str.tostring(dist52w, "#.##") + "%",
         text_color=distColor(dist52w), text_formatting=text.format_bold)

    // Up/Down Volume Ratio 50 ngày (đánh giá tích lũy/phân phối)
    // 7 mức chi tiết dựa trên U/D ratio + vị trí giá
    udCol = color.black
    string udLabel = ""
    if udRatio >= 1.5 and close > ma50
        udLabel := "Tăng giá"
        udCol := color.green
    else if udRatio >= 1.1 and close > ma50
        udLabel := "Tăng giá sớm"
        udCol := color.teal
    else if udRatio >= 1.5 and close <= ma50
        udLabel := "Tích lũy"
        udCol := color.green
    else if udRatio >= 1.1 and close <= ma50
        udLabel := "Tích lũy sớm"
        udCol := color.teal
    else if udRatio >= 0.9 and udRatio < 1.1
        udLabel := "Sideway"
        udCol := color.gray
    else if udRatio >= 0.7 and udRatio < 0.9
        udLabel := "Phân phối sớm"
        udCol := color.orange
    else
        udLabel := "Phân phối"
        udCol := color.red
    table.cell(maTable, 0, 7, "U/D Vol", text_color=color.black)
    table.cell(maTable, 1, 7, str.tostring(udRatio, "#.##") + " — " + udLabel,
         text_color=udCol, text_formatting=text.format_bold)

    // Minervini Trend Template — xác định Stage
    string trendText = ""
    color trendCol = color.black
    if trendScore == 7
        trendText := "Stage 2 ✓ (" + str.tostring(trendScore) + "/7)"
        trendCol := color.green
    else if trendScore >= 5 and close > ma150 and close > ma50
        trendText := "Stage 2 sớm (" + str.tostring(trendScore) + "/7)"
        trendCol := color.green
    else if close > ma150 and close < ma50
        // Giá trên MA150 nhưng dưới MA50 → đang yếu dần (Stage 3)
        trendText := "Stage 3 ⚠ (" + str.tostring(trendScore) + "/7)"
        trendCol := color.orange
    else if close < ma150 and close < ma200
        // Giá dưới cả MA150 và MA200 → downtrend (Stage 4)
        trendText := "Stage 4 ▼ (" + str.tostring(trendScore) + "/7)"
        trendCol := color.red
    else
        // Giá quanh MA, chưa xác định rõ → nền tích lũy (Stage 1)
        trendText := "Stage 1 — (" + str.tostring(trendScore) + "/7)"
        trendCol := color.gray
    table.cell(maTable, 0, 8, "SEPA", text_color=color.black)
    table.cell(maTable, 1, 8, trendText,
         text_color=trendCol, text_formatting=text.format_bold)

    // Base Count — đếm số lần breakout trong uptrend
    baseCol = baseCount <= 2 ? color.green : baseCount <= 3 ? color.orange : color.red
    baseLabel = baseCount == 0 ? "Chưa có" : baseCount <= 2 ? "Tốt" : baseCount == 3 ? "Cẩn thận" : "Muộn"
    table.cell(maTable, 0, 9, "Base", text_color=color.black)
    table.cell(maTable, 1, 9, "Lần " + str.tostring(baseCount) + " — " + baseLabel,
         text_color=baseCol, text_formatting=text.format_bold)

    // Số phiên phân phối 25 ngày (O'Neil: ≥ 5 = nguy hiểm)
    distCol = distDayCount >= 5 ? color.red : distDayCount >= 3 ? color.orange : color.green
    table.cell(maTable, 0, 10, "Dist Day", text_color=color.black)
    table.cell(maTable, 1, 10, str.tostring(distDayCount) + "/25 ngày",
         text_color=distCol, text_formatting=text.format_bold)

    // Main Force Score — smart money đang mua hay bán
    mfCol = mainForceScore >= 70 ? color.green : mainForceScore < 40 ? color.red : color.black
    mfLabel = mainForceScore >= 70 ? "Mua vào" : mainForceScore >= 40 ? "Trung tính" : "Bán ra"
    table.cell(maTable, 0, 11, "MF Score", text_color=color.black)
    table.cell(maTable, 1, 11, str.tostring(mainForceScore) + " — " + mfLabel,
         text_color=mfCol, text_formatting=text.format_bold)

// --- Bảng phân tích cơ bản (góc dưới phải) ---
// Hiện các chỉ số: rẻ/đắt, tăng trưởng, tiềm năng
// Chỉ hiện bảng FA khi mở cổ phiếu (không hiện cho index/ETF)
isStock = syminfo.type == "stock"
showFundTable = input.bool(true, "Bảng cơ bản", group="Hiển thị")

// Lấy dữ liệu tài chính từ TradingView (dùng ID chính xác từ docs)
// Lưu ý: request.financial trả về na cho index/ETF — không gây lỗi nhưng không có data
epsTTM    = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE_DILUTED", "TTM", ignore_invalid_symbol=true)
bvps      = request.financial(syminfo.tickerid, "BOOK_VALUE_PER_SHARE", "FQ", ignore_invalid_symbol=true)
roe       = request.financial(syminfo.tickerid, "RETURN_ON_EQUITY", "FQ", ignore_invalid_symbol=true)
epsGrowth = request.financial(syminfo.tickerid, "EARNINGS_PER_SHARE_DILUTED_ONE_YEAR_GROWTH", "FQ", ignore_invalid_symbol=true)
revGrowth = request.financial(syminfo.tickerid, "REVENUE_ONE_YEAR_GROWTH", "FQ", ignore_invalid_symbol=true)
pretaxMargin = request.financial(syminfo.tickerid, "NET_MARGIN", "FQ", ignore_invalid_symbol=true)

// Tự tính P/E, P/B, PEG
peRatio = epsTTM > 0 ? close / epsTTM : na
pbRatio = bvps > 0 ? close / bvps : na
// PEG = P/E chia cho EPS growth (Peter Lynch: < 1 = rẻ so với tăng trưởng)
pegRatio = not na(peRatio) and not na(epsGrowth) and epsGrowth > 0 ? peRatio / epsGrowth : na

var table fundTable = table.new(position.middle_left, 2, 11,
     bgcolor=color.new(color.white, 0),
     frame_color=color.black, frame_width=1,
     border_color=color.gray, border_width=1)

if barstate.islast and showFundTable and isStock
    // Tiêu đề
    table.cell(fundTable, 0, 0, "Cơ bản", text_color=color.white,
         bgcolor=color.black, text_formatting=text.format_bold)
    table.cell(fundTable, 1, 0, "Giá trị", text_color=color.white,
         bgcolor=color.black, text_formatting=text.format_bold)

    // P/E — rẻ hay đắt
    peCol = na(peRatio) ? color.gray : peRatio < 20 ? color.green : peRatio > 40 ? color.red : color.black
    peText = na(peRatio) ? "N/A" : str.tostring(peRatio, "#.#")
    table.cell(fundTable, 0, 1, "P/E", text_color=color.black)
    table.cell(fundTable, 1, 1, peText,
         text_color=peCol, text_formatting=text.format_bold)

    // PEG — Peter Lynch: P/E so với tốc độ tăng trưởng
    // < 1 = undervalued (tăng trưởng nhanh hơn giá), > 2 = đắt
    pegCol = na(pegRatio) ? color.gray : pegRatio < 1 ? color.green : pegRatio > 2 ? color.red : color.black
    pegText = na(pegRatio) ? "N/A" : str.tostring(pegRatio, "#.##")
    table.cell(fundTable, 0, 2, "PEG", text_color=color.black)
    table.cell(fundTable, 1, 2, pegText,
         text_color=pegCol, text_formatting=text.format_bold)

    // ROE — hiệu quả sử dụng vốn (Minervini: > 17%)
    roeCol = na(roe) ? color.gray : roe > 17 ? color.green : roe < 10 ? color.red : color.black
    roeText = na(roe) ? "N/A" : str.tostring(roe, "#.#") + "%"
    table.cell(fundTable, 0, 3, "ROE", text_color=color.black)
    table.cell(fundTable, 1, 3, roeText,
         text_color=roeCol, text_formatting=text.format_bold)

    // EPS Growth YoY — Minervini/O'Neil: > 25% mỗi quý
    epsGCol = na(epsGrowth) ? color.gray : epsGrowth > 25 ? color.green : epsGrowth < 0 ? color.red : color.black
    epsGText = na(epsGrowth) ? "N/A" : str.tostring(epsGrowth, "#.#") + "%"
    table.cell(fundTable, 0, 4, "EPS ▲", text_color=color.black)
    table.cell(fundTable, 1, 4, epsGText,
         text_color=epsGCol, text_formatting=text.format_bold)

    // Revenue Growth YoY — Minervini: > 25%
    revGCol = na(revGrowth) ? color.gray : revGrowth > 25 ? color.green : revGrowth < 0 ? color.red : color.black
    revGText = na(revGrowth) ? "N/A" : str.tostring(revGrowth, "#.#") + "%"
    table.cell(fundTable, 0, 5, "Rev ▲", text_color=color.black)
    table.cell(fundTable, 1, 5, revGText,
         text_color=revGCol, text_formatting=text.format_bold)

    // Net Margin — biên lợi nhuận ròng (sau thuế, lãi vay)
    marginCol = na(pretaxMargin) ? color.gray : pretaxMargin > 15 ? color.green : pretaxMargin < 5 ? color.red : color.black
    marginText = na(pretaxMargin) ? "N/A" : str.tostring(pretaxMargin, "#.#") + "%"
    table.cell(fundTable, 0, 6, "Net Margin", text_color=color.black)
    table.cell(fundTable, 1, 6, marginText,
         text_color=marginCol, text_formatting=text.format_bold)

    // EPS TTM hiện tại
    epsCol = na(epsTTM) ? color.gray : epsTTM > 0 ? color.green : color.red
    epsText = na(epsTTM) ? "N/A" : str.tostring(epsTTM, format.mintick)
    table.cell(fundTable, 0, 7, "EPS", text_color=color.black)
    table.cell(fundTable, 1, 7, epsText,
         text_color=epsCol, text_formatting=text.format_bold)

    // P/B
    pbCol = na(pbRatio) ? color.gray : pbRatio < 2 ? color.green : pbRatio > 5 ? color.red : color.black
    pbText = na(pbRatio) ? "N/A" : str.tostring(pbRatio, "#.##")
    table.cell(fundTable, 0, 8, "P/B", text_color=color.black)
    table.cell(fundTable, 1, 8, pbText,
         text_color=pbCol, text_formatting=text.format_bold)

    // Phân loại cổ phiếu: Tăng trưởng / Phục hồi / Ổn định / Suy giảm
    // Growth: EPS > 25% hoặc Rev > 20%, VÀ Net Margin > 5% (loại bỏ phục hồi từ lỗ)
    // Phục hồi: EPS > 25% nhưng Net Margin ≤ 5% (vừa thoát lỗ, chưa bền)
    // Ổn định: EPS 0-25% và Rev 0-20%
    // Suy giảm: cả EPS < 0 VÀ Rev < 0 (cả hai cùng xấu)
    string stockType = ""
    color typeCol = color.gray
    if not na(epsGrowth) and not na(revGrowth)
        if (epsGrowth > 25 or revGrowth > 20) and epsGrowth >= 0 and (na(pretaxMargin) or pretaxMargin > 5)
            stockType := "🚀 Tăng trưởng"
            typeCol := color.green
        else if epsGrowth > 25 and (na(pretaxMargin) or pretaxMargin <= 5)
            stockType := "📈 Phục hồi"
            typeCol := color.orange
        else if epsGrowth < 0 and revGrowth < 0
            stockType := "⚠️ Suy giảm"
            typeCol := color.red
        else
            stockType := "⚖️ Ổn định"
            typeCol := color.blue
    else
        stockType := "N/A"
    table.cell(fundTable, 0, 9, "Loại", text_color=color.black)
    table.cell(fundTable, 1, 9, stockType,
         text_color=typeCol, text_formatting=text.format_bold)

    // Fair Value ước tính
    // Growth stock: EPS × min(EPS growth, 30) — PEG-based
    // Ổn định: Graham Number = √(22.5 × EPS × Book Value)
    string fvText = "N/A"
    color fvCol = color.gray
    if not na(epsTTM) and epsTTM > 0
        float fairVal = 0.0
        if not na(epsGrowth) and epsGrowth > 25
            // Growth: fair P/E = min(EPS growth, 15) — Peter Lynch, cap 15 cho thị trường VN
            fairVal := epsTTM * math.min(epsGrowth, 15)
        else if not na(bvps) and bvps > 0
            // Ổn định: Graham Number
            fairVal := math.sqrt(22.5 * epsTTM * bvps)
        else
            fairVal := epsTTM * 15  // Fallback: P/E 15
        float upside = (fairVal - close) / close * 100
        fvText := str.tostring(fairVal, format.mintick) + " (" + str.tostring(upside, "#.#") + "%)"
        fvCol := upside > 20 ? color.green : upside < -10 ? color.red : color.black
    table.cell(fundTable, 0, 10, "Fair Value", text_color=color.black)
    table.cell(fundTable, 1, 10, fvText,
         text_color=fvCol, text_formatting=text.format_bold)
