//@version=6
indicator("Seasonality", overlay=true)

// --- Tính % thay đổi mỗi tháng qua tất cả các năm trong lịch sử ---

// Biến tích lũy cho mỗi tháng (index 0-11)
var float[] monthSum = array.new_float(12, 0.0)
var int[] monthCount = array.new_int(12, 0)
var int[] monthWin = array.new_int(12, 0)
var float[] monthMax = array.new_float(12, -999.0)
var float[] monthMin = array.new_float(12, 999.0)

// Phát hiện bar đầu tiên của mỗi tháng mới
isNewMonth = month != month[1]

var float monthOpen = na
if na(monthOpen)
    monthOpen := close

if isNewMonth
    int prevMonth = month[1] - 1
    float monthReturn = not na(monthOpen) and monthOpen > 0 ? (close[1] - monthOpen) / monthOpen * 100 : 0.0

    array.set(monthSum, prevMonth, array.get(monthSum, prevMonth) + monthReturn)
    array.set(monthCount, prevMonth, array.get(monthCount, prevMonth) + 1)
    if monthReturn > 0
        array.set(monthWin, prevMonth, array.get(monthWin, prevMonth) + 1)
    if monthReturn > array.get(monthMax, prevMonth)
        array.set(monthMax, prevMonth, monthReturn)
    if monthReturn < array.get(monthMin, prevMonth)
        array.set(monthMin, prevMonth, monthReturn)

    monthOpen := open

// --- Bảng Seasonality (góc trái dưới) ---
var table seasTable = table.new(position.bottom_left, 5, 14,
     bgcolor=color.new(color.white, 0),
     frame_color=color.black, frame_width=1,
     border_color=color.gray, border_width=1)

if barstate.islast
    // Header
    table.cell(seasTable, 0, 0, "Tháng", text_color=color.white, bgcolor=color.black, text_formatting=text.format_bold)
    table.cell(seasTable, 1, 0, "Avg %", text_color=color.white, bgcolor=color.black, text_formatting=text.format_bold)
    table.cell(seasTable, 2, 0, "Win", text_color=color.white, bgcolor=color.black, text_formatting=text.format_bold)
    table.cell(seasTable, 3, 0, "Best", text_color=color.white, bgcolor=color.black, text_formatting=text.format_bold)
    table.cell(seasTable, 4, 0, "Worst", text_color=color.white, bgcolor=color.black, text_formatting=text.format_bold)

    string[] monthNames = array.from("T1", "T2", "T3", "T4", "T5", "T6", "T7", "T8", "T9", "T10", "T11", "T12")

    for i = 0 to 11
        int cnt = array.get(monthCount, i)
        float avg = cnt > 0 ? array.get(monthSum, i) / cnt : 0.0
        int wins = array.get(monthWin, i)
        float winRate = cnt > 0 ? float(wins) / float(cnt) * 100 : 0.0
        float best = array.get(monthMax, i)
        float worst = array.get(monthMin, i)

        // Màu theo avg
        color rowCol = avg > 2 ? color.green : avg > 0 ? color.teal : avg > -1 ? color.black : color.red

        // Highlight tháng hiện tại
        color bgCol = (i == month - 1) ? color.new(color.yellow, 80) : color.new(color.white, 100)

        string sign = avg >= 0 ? "+" : ""
        string bestStr = best > -999 ? "+" + str.tostring(best, "#.#") : "—"
        string worstStr = worst < 999 ? str.tostring(worst, "#.#") : "—"

        table.cell(seasTable, 0, i + 1, array.get(monthNames, i), text_color=color.black, bgcolor=bgCol)
        table.cell(seasTable, 1, i + 1, sign + str.tostring(avg, "#.#") + "%", text_color=rowCol, bgcolor=bgCol, text_formatting=text.format_bold)
        table.cell(seasTable, 2, i + 1, str.tostring(winRate, "#") + "%", text_color=rowCol, bgcolor=bgCol)
        table.cell(seasTable, 3, i + 1, bestStr, text_color=color.green, bgcolor=bgCol)
        table.cell(seasTable, 4, i + 1, worstStr, text_color=color.red, bgcolor=bgCol)

    // Dòng cuối: tổng kết
    float bestAvg = -999.0
    int bestMonth = 0
    for i = 0 to 11
        int cnt = array.get(monthCount, i)
        float avg = cnt > 0 ? array.get(monthSum, i) / cnt : 0.0
        if avg > bestAvg
            bestAvg := avg
            bestMonth := i
    table.cell(seasTable, 0, 13, "★", text_color=color.black, bgcolor=color.new(color.green, 85))
    table.cell(seasTable, 1, 13, array.get(monthNames, bestMonth), text_color=color.green, bgcolor=color.new(color.green, 85), text_formatting=text.format_bold)
    table.cell(seasTable, 2, 13, "+" + str.tostring(bestAvg, "#.#") + "%", text_color=color.green, bgcolor=color.new(color.green, 85), text_formatting=text.format_bold)
    table.cell(seasTable, 3, 13, "", bgcolor=color.new(color.green, 85))
    table.cell(seasTable, 4, 13, "", bgcolor=color.new(color.green, 85))
